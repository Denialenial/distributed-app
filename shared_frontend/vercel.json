{
    "version": 2,
    "builds": [
      {
        "src": "shared_frontend/package.json",
        "use": "@vercel/static-build",
        "config": { "distDir": "shared_frontend/build" }
      }
    ],
    "routes": [
      {
        "src": "/(.*)",
        "dest": "/index.html"
      }
    ]
  }
  